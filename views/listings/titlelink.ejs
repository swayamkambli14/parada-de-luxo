<% layout("/layouts/boilerplate") %>
<head>
    <title>Document</title>
    <style>
        li{border: 1px solid gray; padding: 8px; margin: 5px 0;border-radius: 5px; }
    </style>
</head>
<body>

    <div class="row row-cols-lg-3"> 
    <% for(let listing of allListing){ %>
          
  <div class="card " style="width: 20rem;">
  <a href="/listings/<%= listing._id %>">
  <img src="<%= listing.image.url %>" class="card-img-top"  style="height: 20rem;" >
  </a>

  <div class="card-body" >
    <h5 class="card-title"><%= listing.title %></h5>
    <div class="card-details" >
    <ul>  
    <!-- <li><p><%= listing.description %></p></li>  -->
    <li> <p> &#x20B9  <%= listing.price.toLocaleString("en-IN") %> /night</p></li> 
    <li><p><%= listing.location %></p></li>  
    <li><p><%= listing.country %></p></li>

    </ul>
    <a href="#" class="btn btn-primary">Go somewhere</a>
    </div>
  </div>
</div>

<% } %>
    </div>


