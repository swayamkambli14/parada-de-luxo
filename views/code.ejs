          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 21l-4.35-4.35" stroke="rgba(15,23,42,0.5)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path><circle cx="11" cy="11" r="6" stroke="rgba(15,23,42,0.5)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></circle></svg>
          <input type="search" placeholder="Search destinations, tours..." aria-label="Search" />
        </div>

        <button class="btn btn--ghost" onclick="location.href='#login'">Log in</button>
        <button class="btn btn--primary" onclick="location.href='#book'">Book a Trip</button>

        <button class="hamburger" aria-label="Open menu" onclick="openMobileMenu()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 7h18M3 12h18M3 17h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Compact hero strip that sits below the header (optional) -->
  <section class="hero-compact" aria-label="Quick search and highlights">
    <div class="hero-row">
      <div>
        <h2 class="hero-title">Find your next escape</h2>
        <p class="hero-sub">Hand-picked trips, local guides, and sustainable stays — curated just for you.</p>
      </div>
      <div style="display:flex;gap:10px;align-items:center">
        <a class="btn btn--ghost" href="#explore">Explore Trips</a>
        <a class="btn btn--primary" href="#specials">Limited Offers</a>
      </div>
    </div>
  </section>

