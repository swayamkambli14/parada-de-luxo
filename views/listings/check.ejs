<% layout("/layouts/boilerplate") %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
  <div class="des" style="display: flex;padding-top: 1rem;">
   <ul>
   
      <h5><u><p><%= list.title %></u></h5>
      <li><p><%= list.description %></p></li> 
      <li> <p> &#x20B9  <%= list.price.toLocaleString("en-IN") %> /night</p></li> 
      <li><p><%= list.location %></p></li>  
       <li><p><%= list.country %></p></li>
        <form method="post" action="/uptbtn/<%= list._id %>?_method=PUT">
        <button style="background-color: #fe424d;color: white;border-radius: 5px;border: none;">Update</button>
       </form><br>
       <form method="post" action="/delete/<%= list._id %>?_method=Delete" >
        <button style="background-color:gray;color: white;border-radius: 5px;border: none">Delete</button>
       </form>
   </ul>

<div class="p-4 rounded d-inline-block">
  <img src="<%= list.image.url %>" class="rounded" style="width: 100%; height:60vh;object-fit:cover;align-items: end;">
</div>

   </div>




